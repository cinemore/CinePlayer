    "依赖系统 VideoToolbox 能力，仅部分设备与分辨率支持。": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يعتمد على VideoToolbox، مدعوم في أجهزة ودقة معينة"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Abhängig von VideoToolbox, nur auf ausgewählten Geräten und Auflösungen verfügbar"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Relies on VideoToolbox, supported on limited devices and resolutions"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Dependiente de VideoToolbox, compatible solo con algunos dispositivos y resoluciones"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Dépend de VideoToolbox, supporté sur une sélection de devices et résolutions"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Tergantung kemampuan VideoToolbox, hanya untuk perangkat dan resolusi tertentu"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Dipende da VideoToolbox, compatibile solo su alcuni dispositivi e risoluzioni"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "システムビデオツールボックス依存、一部デバイス・解像度のみ対応。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "시스템 VideoToolbox 기능 활용, 일부 기기 및 해상도 지원"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Depende de VideoToolbox, compatível com poucos dispositivos e resoluções"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Использует VideoToolbox, поддерживается не на всех устройствах и разрешениях"
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ใช้ VideoToolbox, รองรับเฉพาะอุปกรณ์และระดับความละเอียดบางส่วน"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Tận dụng VideoToolbox, hỗ trợ hạn chế trên một số thiết bị và độ phân giải"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "依系統 VideoToolbox 功能，部分機型與解析度支援。"
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Basat en VideoToolbox, compatible amb limitats dispositius i resolucions"
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Využívá VideoToolbox, podporováno na omezeném počtu zařízení a rozlišení"
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Baserer sig på VideoToolbox, understøttes på begrænsede enheder og opløsninger"
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Käyttää VideoToolboxia, toimii rajoitetuilla laitteilla ja resoluutioilla"
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "תלוי ב-VideoToolbox, תואם למכשירים ורזולוציות מוגבלים"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "सिस्टम VideoToolbox पर निर्भर, सीमित उपकरणों और रिज़ॉल्यूशन में समर्थित।"
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Koristi VideoToolbox, podržano na ograničenim uređajima i rezolucijama"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "VideoToolbox-al, korlátozott eszközökön és felдерszámokon"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Gebaseerd op VideoToolbox, alleen op beperkte apparaten en resoluties"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wykorzystuje VideoToolbox, dostępne tylko na wybranych urządzeniach i rozdzielczościach"
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Utilize VideoToolbox, suportat pe dispozitive și rezoluții limitate"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "VideoToolbox'u kullanarak, sınırlı cihazlarda ve çözünürlüklerde çalışır"
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Використовує VideoToolbox, підтримується на обмеженому асортименті пристроїв і роздільних здатностей"
          }
        }
      }
    },
