    "Apple 翻译暂不支持该语言对，已自动关闭字幕翻译。": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple الترجمة لا تدعم هذه اللغة، وتم تعطيل ترجمة الترجمة التلقائية"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Translate unterstützt diese Sprache nicht, Untertitel-Übersetzung automatisch deaktiviert"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Translate does not support this language, and automatic subtitles have been disabled"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Traductor no admite esta lengua para traducción de subtítulos, y la traducción automática está desactivada"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Sous-titres : Désactivés."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Translate belum mendukung bahasa ini, subtitle otomatis dinonaktifkan"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Traduttore non supporta questa lingua, traduzione sottotitoli disattivata"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple 翻訳、この言語での字幕翻訳は自動停止。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple 번역은 현재 지원하지 않습니다. 자동 자막 번역이 중단되었습니다"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Tradutor não suporta este idioma para tradução de legendas, desativando a tradução automática"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Translate не поддерживает этот язык, автоматическая трансляция субтитров отключена"
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple ไม่รองรับภาษา นี้สำหรับการแปล �"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Translate hiện không hỗ trợ ngôn ngữ này, tự động tắt dịch phụ đề"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple 翻譯暫未支援，自動關閉字幕翻譯。"
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Translate no suporta aquesta llengua, i els subtítols automàtics estan desactivat"
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Translate neumožňuje překlad do této jazykové verze, a automatické titulky jsou vypnuty"
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple oversætter understøtter ikke denne sprog, og automatisk undertekster er slået fra"
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Translate ei tue tätä kieltä, ja automaattiset tekstitykset on poistettu"
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple תרגום לא תומך בשפה זו, כתוביות אוטומטיות כבוי"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple अनुवाद वर्तमान में इस भाषा के लिए उपलब्ध नहीं है, और स्वचालित कैप्शन बंद हैं।"
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Translate ne podržava ovu jezičnu varijantu, a automatski su isključeni titlovi"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple űrlap nem támogatja ezt a nyelvet, a fordított feliratok automatikusan letiltva vannak"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Translate ondersteunt deze taal niet, en automatisch ondertiteling is uitgeschakeld"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Translate nie obsługuje tej języka, automatyczne napisy wyłączone"
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Translate nu suportă această limbă, iar traducerile automate de subtitrare au fost dezactivate"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Translate bu dili desteklemiyor, otomatik altyazı devre dışı bırakıldı"
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Translate не підтримує цю мову, автоматичний переклад субтитрів вимкнено"
          }
        }
      }
    },
