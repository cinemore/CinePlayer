    "仅在 1080p 及以下分辨率开放，适合低帧率内容插帧。" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "مناسب لمحتوى منخفض معدل، لعرضه بجودة 1080p أو أقل"
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Només en 1080p o menys, per a la interpolació de vídeo de baixa taxa de fotogrames"
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pouze pro 1080p a méně; vhodné pro interpolaci nízké snímkové frekvence"
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kun i 1080p eller lavere – egnet til frame interpolation ved lav billedfrekvens"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nur in 1080p oder geringerer Auflösung verfügbar, für die Verwendung bei niedrigen Bildraten"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Limited to 1080p and below; suitable for frame interpolation of low frame rate content"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Solo en resolución 1080p o inferior, para interpolación de contenido de baja velocidad de fotogramas"
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "1080p tai vähemmän – sopii alhaisen kuvatehosteen käsittelyyn"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Uniquement en 1080p ou moins, pour l'interpolation de vidéos à faible framerate"
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "רק עד 1080p, מתאים לשיפור תמונה של תוכן בעלות פריימים נמוכה"
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "केवल 1080p या उससे कम रिज़ॉल्यूशन में उपलब्ध, कम फ़्रेम दर सामग्री के लिए उपयुक्त।"
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dostupno u rezoluciji 1080p i nižoj, za interpolaciju videa s niskim frekvencijom"
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Csak 1080p-nál alacsonyabb felbontásban, aljós képinterpolációhoz"
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hanya tersedia pada resolusi 1080p atau lebih rendah, cocok untuk meningkatkan frame pada konten ber-frame rendah"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Disponibile solo in 1080p o inferiore, ideale per l'interpolazione di contenuti a bassa frequenza"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "1080p以下で利用。低フレームレート向け。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "1080p 이하 해상도에서 사용, 저 프레임 콘텐츠에 적합"
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Alleen beschikbaar in 1080p of lager; geschikt voor frame interpolatie van lage framewerken"
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dostępne w rozdzielczości 1080p i mniej, dla interpolacji obrazu z niską liczbą klatek"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Apenas em 1080p ou menos"
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Doar în 1080p sau mai puțin, pentru interpolare de cadre a conținutului cu framă mică"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Только в разрешении 1080p и ниже, для интерполяции кадров"
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "เฉพาะ 1080p หรือต่ำกว่า เหมาะสำหรับภาพความละเอียดต่ำ"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "1080p veya daha düşük çözünürlükte çalışır, düşük kare hızlı içerik için optimizasyon"
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Лише для 1080p та нижче. Підходить для інтерполяції кадрів з низькою частотою кадрів"
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Chỉ hiển thị ở độ phân giải 1080p trở xuống, phù hợp để thêm khung hình"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "只限 1080p 及其以下解析度，適用於低幀率影片補幀。"
          }
        }
      }
    },
    "仅对低像素的视频开启，为实验功能，会增加耗电与发热。" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "لأجهزة الفيديو منخفضة الدقة فقط، لغرض التجارب، قد يزيد من استهلاك الطاقة والحرارة"
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Només per vídeos de baixa resolució – per a experiments, augmenta el consum d'energia i la calor"
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pouze pro videa s nízkým rozlišením – pro testování, zvyšuje spotřebu energie a zahřívání"
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kun for lavopløselige videoer – til test, øger strømforbrug og varme"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nur für niedrige Auflösungen, für Testzwecke – erhöht den Stromverbrauch und die Wärmeentwicklung"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Limited to low-resolution videos – for testing only, increasing power consumption and heat"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Solo para videos de baja resolución, para funciones de prueba, aumenta el consumo y la temperatura"
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vain matalaresoluution videoille, testauskäyttöön – lisää virrankulutusta ja lämpöä"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Uniquement pour vidéos basse résolution, pour tests, augmente la consommation et la chaleur"
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "רק לסרטוני ל-Low Resolution – לשימוש ניסיוני, יגרום לצריכת חשמל גבוהה יותר וחימום"
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "केवल निम्न-रिज़ॉल्यूशन वीडियो के लिए, परीक्षण हेतु, बिजली और गर्मी बढ़ेगी।"
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Samo za videoje niske rezolucije – za testiranje, povećava potrošnju energije i toplinu"
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Csak alacsony felbontású videókhoz, kizárólag tesztelésre, ami növeli a fogyasztást és a hőmérsékletet"
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hanya untuk video resolusi rendah, untuk fungsi eksperimen, akan meningkatkan konsumsi daya dan panas"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Solo per video a bassa risoluzione, per funzionalità di test – aumenta consumo batteria e calore"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "低解像度動画用 (実験機能、電力・発熱が増加)"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "저해상 영상에만 적용, 실험 기능으로, 배터리 소모 및 발열이 증가합니다"
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Alleen voor lage resolutie video's – voor testen, verhoogt stroomverbruik en warmte"
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tylko dla wideo niskiej rozdzielczości – do testów, zwiększa zużycie energii i nagrzewanie"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Apenas para vídeos de baixa resolução, para fins de teste. Aumenta consumo e calor"
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Doar pentru video-uri de rezoluție scăzută – pentru testare, consumă mai multă energie și generează căldură"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Только для видео с низкой детализацией, для экспериментальной функции, увеличивает расход энергии и нагрев"
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "เฉพาะสำหรับวิดีโอความละเอียดต่ำ, สำหรับทดสอบ, จะทำให้แบตเตอรี่ร้อนขึ้นและใช้พลังงานมากขึ้น"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Düşük çözünürlüklü videolar için, yalnızca test amaçlı, pil tüketimini ve ısınmayı artırır"
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Тільки для відео низької роздільності – для тестування, збільшує споживання енергії та нагрівання"
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Chỉ dành cho video độ phân giải thấp, dùng cho thử nghiệm – có thể tăng tiêu hao pin và nhiệt"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "僅限低解析度影片。實驗功能，會增加耗電與發熱。"
          }
        }
      }
    },
